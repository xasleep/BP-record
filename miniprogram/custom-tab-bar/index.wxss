.tabbar-shell {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 999;
  padding: 12rpx 24rpx calc(12rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.62);
  box-shadow: 0 -12rpx 36rpx rgba(38, 76, 120, 0.08);
  backdrop-filter: blur(24rpx);
  -webkit-backdrop-filter: blur(24rpx);
}

.tabbar {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  align-items: center;
  min-height: 104rpx;
}

.tab-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  color: #CBD3DF;
}

.tab-icon {
  position: relative;
  width: 40rpx;
  height: 40rpx;
  color: currentColor;
}

.tab-text {
  font-size: 20rpx;
  font-weight: 600;
  line-height: 24rpx;
}

.tab-item.active {
  color: #4F7CFF;
}

.icon-home::before {
  position: absolute;
  top: 5rpx;
  left: 7rpx;
  width: 26rpx;
  height: 23rpx;
  border-radius: 5rpx;
  background: currentColor;
  content: "";
  transform: rotate(45deg);
}

.icon-home::after {
  position: absolute;
  right: 9rpx;
  bottom: 5rpx;
  left: 9rpx;
  height: 22rpx;
  border-radius: 5rpx 5rpx 7rpx 7rpx;
  background: currentColor;
  content: "";
}

.icon-data::before,
.icon-data::after {
  position: absolute;
  bottom: 6rpx;
  width: 9rpx;
  border-radius: 8rpx;
  background: currentColor;
  content: "";
}

.icon-data::before {
  left: 8rpx;
  height: 20rpx;
}

.icon-data::after {
  right: 8rpx;
  height: 28rpx;
}

.icon-data {
  background:
    linear-gradient(currentColor, currentColor) center 15rpx / 9rpx 23rpx no-repeat;
  border-radius: 8rpx;
}

.icon-mine::before {
  position: absolute;
  top: 4rpx;
  left: 50%;
  width: 17rpx;
  height: 17rpx;
  border-radius: 50%;
  background: currentColor;
  content: "";
  transform: translateX(-50%);
}

.icon-mine::after {
  position: absolute;
  right: 7rpx;
  bottom: 5rpx;
  left: 7rpx;
  height: 18rpx;
  border-radius: 18rpx 18rpx 8rpx 8rpx;
  background: currentColor;
  content: "";
}
