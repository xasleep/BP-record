<view class="page {{fontClass}}">
  <view class="range-switch">
    <button class="switch-button {{rangeDays === 7 ? 'active' : ''}}" data-days="7" bindtap="changeRange">7天</button>
    <button class="switch-button {{rangeDays === 30 ? 'active' : ''}}" data-days="30" bindtap="changeRange">30天</button>
  </view>

  <view class="card chart-card">
    <view class="section-title">血压趋势</view>
    <view class="legend-row">
      <text class="legend red">收缩压</text>
      <text class="legend blue">舒张压</text>
      <text class="legend gray">120/80参考线</text>
    </view>
    <view wx:if="{{bpEmpty}}" class="chart-empty">至少需要 2 天记录才能生成趋势图</view>
    <canvas type="2d" id="bpCanvas" class="chart-canvas {{bpEmpty ? 'chart-hidden' : ''}}"></canvas>
  </view>

  <view class="card chart-card">
    <view class="section-title">心率趋势</view>
    <view class="legend-row">
      <text class="legend green">心率</text>
    </view>
    <view wx:if="{{hrEmpty}}" class="chart-empty">至少需要 2 天记录才能生成趋势图</view>
    <canvas type="2d" id="hrCanvas" class="chart-canvas {{hrEmpty ? 'chart-hidden' : ''}}"></canvas>
  </view>
</view>
