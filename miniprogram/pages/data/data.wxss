.range-switch {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.switch-button {
  height: 76rpx;
  border: 2rpx solid #D1D5DB;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.72);
  color: #374151;
  font-size: 30rpx;
  line-height: 76rpx;
}

.switch-button.active {
  border-color: #4A90D9;
  background: rgba(232, 243, 255, 0.9);
  color: #4A90D9;
  font-weight: 700;
}

.chart-card {
  min-height: 520rpx;
}

.legend-row {
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx;
  margin-bottom: 20rpx;
}

.legend {
  position: relative;
  padding-left: 22rpx;
  color: #6B7280;
  font-size: 24rpx;
}

.legend::before {
  position: absolute;
  top: 50%;
  left: 0;
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  content: "";
  transform: translateY(-50%);
}

.red::before {
  background: #FF4D4F;
}

.blue::before {
  background: #4A90D9;
}

.green::before {
  background: #52C41A;
}

.gray::before {
  background: #999999;
}

.chart-canvas {
  width: 100%;
  height: 360rpx;
}

.chart-hidden {
  position: absolute;
  left: -9999rpx;
}

.chart-empty {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 360rpx;
  color: #6B7280;
  text-align: center;
}
