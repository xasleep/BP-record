.record-button {
  margin-bottom: 24rpx;
}

.calendar-card {
  padding-bottom: 20rpx;
}

.month-header,
.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.month-title {
  color: #111827;
  font-size: 36rpx;
  font-weight: 700;
}

.month-button {
  width: 72rpx;
  height: 72rpx;
  border-radius: 8rpx;
  background: #EEF6FF;
  color: #4A90D9;
  font-size: 44rpx;
  line-height: 72rpx;
}

.week-row,
.calendar-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
}

.week-row {
  margin-top: 28rpx;
}

.week-cell {
  color: #6B7280;
  text-align: center;
  font-size: 26rpx;
}

.day-cell {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 82rpx;
  color: #111827;
}

.day-muted {
  color: #CBD5E1;
}

.today .day-number {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #E8F3FF;
  color: #4A90D9;
  line-height: 48rpx;
  text-align: center;
}

.status-dot {
  position: absolute;
  bottom: 8rpx;
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
}

.status-normal {
  background: #52C41A;
}

.status-high {
  background: #FF4D4F;
}

.status-low {
  background: #FAAD14;
}

.link-button {
  padding: 0 4rpx;
  background: transparent;
  color: #4A90D9;
  font-size: 28rpx;
  line-height: 48rpx;
}

.empty {
  padding: 36rpx 0;
  color: #6B7280;
  text-align: center;
}

.record-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 22rpx 0;
  border-bottom: 1rpx solid #EEF2F7;
}

.record-row:last-child {
  border-bottom: 0;
}

.record-date {
  margin-bottom: 8rpx;
  color: #6B7280;
  font-size: 26rpx;
}

.record-value {
  position: relative;
  display: flex;
  align-items: center;
  gap: 16rpx;
  font-weight: 700;
}

.inline {
  position: static;
  display: inline-block;
  flex: 0 0 14rpx;
  width: 14rpx;
  height: 14rpx;
}

.heart-rate {
  color: #374151;
  font-size: 28rpx;
}
