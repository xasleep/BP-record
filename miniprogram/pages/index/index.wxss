.record-hero {
  position: relative;
  display: grid;
  grid-template-columns: 112rpx 1fr 72rpx;
  align-items: center;
  width: 100%;
  min-height: 176rpx;
  margin-bottom: 24rpx;
  padding: 24rpx 28rpx;
  border-radius: 18rpx;
  background: linear-gradient(135deg, #5F86FF 0%, #4A7CF4 48%, #5B93FF 100%);
  box-shadow: 0 18rpx 48rpx rgba(74, 124, 244, 0.28);
  color: #FFFFFF;
  line-height: 1;
  overflow: hidden;
}

.record-hero::after {
  position: absolute;
  top: -60rpx;
  right: -28rpx;
  width: 220rpx;
  height: 220rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.12);
  content: "";
}

.record-plus {
  position: relative;
  z-index: 1;
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.96);
  color: #4E79F7;
  font-size: 66rpx;
  font-weight: 500;
  line-height: 88rpx;
  text-align: center;
}

.record-copy {
  position: relative;
  z-index: 1;
  min-width: 0;
  text-align: left;
}

.record-title {
  margin-bottom: 18rpx;
  color: #FFFFFF;
  font-size: 38rpx;
  font-weight: 800;
  line-height: 42rpx;
}

.record-subtitle {
  color: rgba(255, 255, 255, 0.88);
  font-size: 28rpx;
  line-height: 32rpx;
}

.record-arrow {
  position: relative;
  z-index: 1;
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.14);
  color: #FFFFFF;
  font-size: 58rpx;
  line-height: 62rpx;
  text-align: center;
}

.calendar-card {
  padding-bottom: 20rpx;
}

.month-header,
.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.month-title {
  color: #111827;
  font-size: 36rpx;
  font-weight: 700;
}

.month-button {
  width: 72rpx;
  height: 72rpx;
  border-radius: 14rpx;
  background: rgba(238, 246, 255, 0.82);
  color: #4A90D9;
  font-size: 44rpx;
  line-height: 72rpx;
}

.week-row,
.calendar-grid {
  display: grid;
  grid-template-columns: repeat(7, 1fr);
}

.week-row {
  margin-top: 28rpx;
}

.week-cell {
  color: #6B7280;
  text-align: center;
  font-size: 26rpx;
}

.day-cell {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 82rpx;
  color: #111827;
}

.day-muted {
  color: #CBD5E1;
}

.today .day-number {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: #E8F3FF;
  color: #4A90D9;
  line-height: 48rpx;
  text-align: center;
}

.status-dot {
  position: absolute;
  bottom: 8rpx;
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
}

.status-normal {
  background: #52C41A;
}

.status-high {
  background: #FF4D4F;
}

.status-low {
  background: #FAAD14;
}

.link-button {
  padding: 0 4rpx;
  background: transparent;
  color: #4A90D9;
  font-size: 28rpx;
  line-height: 48rpx;
}

.empty {
  padding: 36rpx 0;
  color: #6B7280;
  text-align: center;
}

.record-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 22rpx 0;
  border-bottom: 1rpx solid #EEF2F7;
}

.record-row:last-child {
  border-bottom: 0;
}

.record-date {
  margin-bottom: 8rpx;
  color: #6B7280;
  font-size: 26rpx;
}

.record-value {
  position: relative;
  display: flex;
  align-items: center;
  gap: 16rpx;
  font-weight: 700;
}

.inline {
  position: static;
  display: inline-block;
  flex: 0 0 14rpx;
  width: 14rpx;
  height: 14rpx;
}

.heart-rate {
  color: #374151;
  font-size: 28rpx;
}
