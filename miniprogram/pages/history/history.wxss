.filter-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
  color: #374151;
  font-weight: 700;
}

.clear-button {
  padding: 0 20rpx;
  border-radius: 8rpx;
  background: #E8F3FF;
  color: #4A90D9;
  font-size: 28rpx;
  line-height: 64rpx;
}

.empty {
  padding: 64rpx 0;
  color: #6B7280;
  text-align: center;
}

.record-top,
.values {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.record-date {
  color: #111827;
  font-weight: 700;
}

.record-time {
  margin-top: 6rpx;
  color: #6B7280;
  font-size: 26rpx;
}

.status-pill {
  min-width: 92rpx;
  padding: 10rpx 18rpx;
  border-radius: 8rpx;
  color: #FFFFFF;
  font-size: 26rpx;
  text-align: center;
}

.status-normal {
  background: #52C41A;
}

.status-high {
  background: #FF4D4F;
}

.status-low {
  background: #FAAD14;
}

.values {
  margin-top: 28rpx;
  padding: 24rpx 0;
  border-top: 1rpx solid #EEF2F7;
  border-bottom: 1rpx solid #EEF2F7;
}

.value-item {
  display: flex;
  flex: 1;
  flex-direction: column;
  align-items: center;
}

.value-number {
  color: #111827;
  font-size: 44rpx;
  font-weight: 700;
}

.value-label {
  margin-top: 8rpx;
  color: #6B7280;
  font-size: 24rpx;
}

.medication {
  margin-top: 20rpx;
  color: #374151;
  line-height: 1.6;
}
