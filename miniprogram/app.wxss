page {
  min-height: 100%;
  background: linear-gradient(180deg, #EDF5FF 0%, #F6F8FC 42%, #F3F5F9 100%);
  color: #1F2937;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Helvetica, sans-serif;
}

view,
text,
input,
textarea,
button {
  box-sizing: border-box;
}

button {
  margin: 0;
}

.page {
  min-height: 100vh;
  padding: 24rpx 24rpx 152rpx;
  background: linear-gradient(180deg, #EDF5FF 0%, #F7F9FD 46%, #F3F5F9 100%);
}

.font-small {
  font-size: 28rpx;
}

.font-medium {
  font-size: 32rpx;
}

.font-large {
  font-size: 40rpx;
}

.card {
  margin-bottom: 24rpx;
  padding: 28rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.72);
  border-radius: 18rpx;
  background: rgba(255, 255, 255, 0.76);
  box-shadow: 0 16rpx 44rpx rgba(37, 80, 128, 0.1);
  backdrop-filter: blur(18rpx);
  -webkit-backdrop-filter: blur(18rpx);
}

.section-title {
  margin-bottom: 20rpx;
  color: #111827;
  font-size: 36rpx;
  font-weight: 700;
}

.muted {
  color: #6B7280;
}

.primary-button {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 96rpx;
  border-radius: 18rpx;
  background: #4A90D9;
  color: #FFFFFF;
  font-size: 36rpx;
  font-weight: 700;
  line-height: 96rpx;
}

.secondary-button {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 80rpx;
  border: 2rpx solid #D1D5DB;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.76);
  color: #374151;
  font-size: 30rpx;
  line-height: 80rpx;
}
