page {
  min-height: 100%;
  background: #F5F7FA;
  color: #1F2937;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Helvetica, sans-serif;
}

view,
text,
input,
textarea,
button {
  box-sizing: border-box;
}

button {
  margin: 0;
}

.page {
  min-height: 100vh;
  padding: 24rpx;
  background: #F5F7FA;
}

.font-small {
  font-size: 28rpx;
}

.font-medium {
  font-size: 32rpx;
}

.font-large {
  font-size: 40rpx;
}

.card {
  margin-bottom: 24rpx;
  padding: 28rpx;
  border-radius: 8rpx;
  background: #FFFFFF;
  box-shadow: 0 8rpx 24rpx rgba(31, 41, 55, 0.06);
}

.section-title {
  margin-bottom: 20rpx;
  color: #111827;
  font-size: 36rpx;
  font-weight: 700;
}

.muted {
  color: #6B7280;
}

.primary-button {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 96rpx;
  border-radius: 8rpx;
  background: #4A90D9;
  color: #FFFFFF;
  font-size: 36rpx;
  font-weight: 700;
  line-height: 96rpx;
}

.secondary-button {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 80rpx;
  border: 2rpx solid #D1D5DB;
  border-radius: 8rpx;
  background: #FFFFFF;
  color: #374151;
  font-size: 30rpx;
  line-height: 80rpx;
}
